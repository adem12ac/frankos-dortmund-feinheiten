# =============================================================
# Frankos Balkan Food — Environment Variables
# Kopieren nach .env (lokal) bzw. in Vercel unter
# Project → Settings → Environment Variables eintragen.
# Alle Variablen sind SERVER-ONLY und landen nie im Client-Bundle.
# =============================================================

# --- Supabase (Project → Settings → API) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # "service_role" Key — geheim halten!

# --- Stripe (Dashboard → Entwickler → API-Schlüssel) ---
STRIPE_SECRET_KEY=sk_test_...      # für Produktion: sk_live_...
# Signing Secret des Webhook-Endpunkts /api/stripe-webhook
# (Dashboard → Entwickler → Webhooks → Endpunkt → Signaturgeheimnis)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Admin-Dashboard (/admin) ---
ADMIN_PASSWORD=bitte-ein-langes-sicheres-passwort
# Beliebiger zufälliger String (min. 32 Zeichen), signiert die Session-Cookies.
# Erzeugen z. B. mit: openssl rand -base64 48
ADMIN_SESSION_SECRET=
